#!/bin/bash
(
set -e
# ждём, пока шаблон развернёт ai-toolkit и venv
while [ ! -d /workspace/ai-toolkit/.git ] || [ ! -f /venv/main/bin/activate ]; do sleep 5; done
source /venv/main/bin/activate
cd /workspace/ai-toolkit
git fetch origin
if [ "$(git rev-parse HEAD)" != "$(git rev-parse origin/main)" ]; then
    git checkout -B main origin/main
    pip install -r requirements.txt
    cd ui && npm install && npm run update_db && npm run build
    # ждём, пока поднимется supervisor, и перезапускаем сервис с новым кодом
    for i in $(seq 1 60); do supervisorctl status >/dev/null 2>&1 && break; sleep 5; done
    supervisorctl restart ai-toolkit || true
else
    echo "Уже актуальная версия, обновление не требуется"
fi
echo "ГОТОВО"
) >> /workspace/update-ai-toolkit.log 2>&1 &
